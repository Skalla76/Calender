<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>📅 Homework Reward Calendar · Money Tracker</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(135deg, #1a7a3a 0%, #0d4d25 100%);
      min-height: 100vh;
      font-family: 'Segoe UI', 'Fredoka', system-ui, sans-serif;
      padding: 0.5rem;
      overflow-x: hidden;
    }

    .app-container {
      max-width: 100%;
      width: 100%;
      margin: 0 auto;
      background: rgba(255, 255, 255, 0.97);
      border-radius: 1.5rem;
      box-shadow: 0 25px 50px rgba(0,0,0,0.3);
      overflow: hidden;
    }

    .header {
      background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
      padding: 1rem;
      color: #1a1a1a;
      text-align: center;
    }

    .header h1 {
      font-size: clamp(1.5rem, 5vw, 2rem);
      margin-bottom: 0.3rem;
      text-shadow: 1px 1px 2px rgba(255,255,255,0.5);
    }

    .header p {
      font-size: clamp(0.8rem, 3vw, 0.95rem);
      font-weight: 600;
    }

    /* Money Counter Banner */
    .money-banner {
      background: linear-gradient(135deg, #1a7a3a 0%, #0d4d25 100%);
      color: #ffd700;
      padding: 1rem;
      display: flex;
      justify-content: space-around;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.8rem;
      border-bottom: 3px solid #ffd700;
    }

    .money-item {
      text-align: center;
      min-width: 100px;
    }

    .money-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #90EE90;
      margin-bottom: 0.2rem;
    }

    .money-value {
      font-size: clamp(1.5rem, 6vw, 2.5rem);
      font-weight: 800;
      color: #ffd700;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    }

    .money-total {
      font-size: clamp(2rem, 8vw, 3.5rem);
      font-weight: 900;
      background: #ffd700;
      color: #1a7a3a;
      padding: 0.3rem 1.5rem;
      border-radius: 50px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    .bonus-indicator {
      background: #ffd700;
      color: #1a7a3a;
      padding: 0.3rem 0.8rem;
      border-radius: 20px;
      font-weight: 700;
      font-size: 0.85rem;
      animation: glow 1.5s infinite;
    }

    @keyframes glow {
      0%, 100% { box-shadow: 0 0 5px #ffd700; }
      50% { box-shadow: 0 0 20px #ffd700, 0 0 30px #ff8c00; }
    }

    .sync-bar {
      background: #2d3436;
      color: white;
      padding: 0.6rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      font-size: clamp(0.7rem, 2.5vw, 0.85rem);
    }

    .sync-status {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .sync-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #00b894;
      animation: pulse 2s infinite;
      flex-shrink: 0;
    }

    @keyframes pulse {
      0% { opacity: 1; }
      50% { opacity: 0.5; }
      100% { opacity: 1; }
    }

    .share-buttons {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }

    .btn {
      padding: 0.4rem 0.8rem;
      border: none;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-size: clamp(0.7rem, 2vw, 0.85rem);
      white-space: nowrap;
      background: white;
      color: #2d3436;
    }

    .btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 3px 10px rgba(0,0,0,0.2);
    }

    .btn:active {
      transform: translateY(0);
    }

    .btn-gold {
      background: #ffd700;
      color: #1a7a3a;
      font-weight: 700;
    }

    .btn-primary {
      background: #00b894;
      color: white;
    }

    .btn-secondary {
      background: #0984e3;
      color: white;
    }

    .content {
      padding: 0.8rem;
    }

    .month-navigation {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      background: #f8f9fa;
      padding: 0.7rem;
      border-radius: 10px;
    }

    .month-title {
      font-size: clamp(1.1rem, 4vw, 1.4rem);
      font-weight: 700;
      color: #2d3436;
    }

    .calendar-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 3px;
      margin-bottom: 1rem;
      min-width: 280px;
    }

    .day-header {
      text-align: center;
      font-weight: 700;
      color: #636e72;
      padding: 0.3rem;
      font-size: clamp(0.6rem, 2.2vw, 0.8rem);
    }

    .day-cell {
      aspect-ratio: 1;
      background: white;
      border: 2px solid #dfe6e9;
      border-radius: 8px;
      padding: 0.3rem;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      position: relative;
    }

    .day-cell:hover {
      transform: scale(1.05);
      border-color: #ffd700;
      box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    }

    .day-cell.today {
      background: #fff9e6;
      border-color: #ffd700;
      box-shadow: 0 0 0 2px rgba(255, 215, 0, 0.3);
    }

    .day-cell.empty {
      background: #f8f9fa;
      cursor: default;
      border-color: #f1f2f6;
    }

    .day-cell.empty:hover {
      transform: none;
      border-color: #f1f2f6;
      box-shadow: none;
    }

    .day-number {
      font-weight: 700;
      font-size: clamp(0.7rem, 2.2vw, 0.9rem);
      margin-bottom: 0.1rem;
    }

    .day-status {
      font-size: clamp(0.9rem, 2.8vw, 1.2rem);
    }

    .day-value {
      position: absolute;
      bottom: 2px;
      right: 4px;
      font-size: 0.55rem;
      font-weight: 700;
      color: #1a7a3a;
      background: #ffd700;
      border-radius: 10px;
      padding: 0 3px;
    }

    .day-cell.completed {
      background: linear-gradient(135deg, #a8e6cf 0%, #88d8b0 100%);
      border-color: #00b894;
    }

    .day-cell.partial {
      background: linear-gradient(135deg, #ffd93d 0%, #f4c531 100%);
      border-color: #f39c12;
    }

    .legend {
      display: flex;
      gap: 0.8rem;
      margin: 0.8rem 0;
      flex-wrap: wrap;
      justify-content: center;
      padding: 0.7rem;
      background: #f8f9fa;
      border-radius: 10px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      font-weight: 600;
      font-size: clamp(0.6rem, 1.8vw, 0.75rem);
    }

    .legend-color {
      width: 18px;
      height: 18px;
      border-radius: 4px;
      flex-shrink: 0;
    }

    .value-legend {
      background: #1a7a3a;
      color: #ffd700;
      padding: 0.6rem;
      border-radius: 8px;
      text-align: center;
      font-size: clamp(0.65rem, 2vw, 0.8rem);
      font-weight: 600;
      margin-bottom: 0.8rem;
    }

    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.7);
      z-index: 1000;
      justify-content: center;
      align-items: center;
      padding: 1rem;
    }

    .modal.active {
      display: flex;
    }

    .modal-content {
      background: white;
      border-radius: 16px;
      padding: 1.5rem;
      max-width: 380px;
      width: 100%;
      box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .modal-content h2 {
      font-size: clamp(1rem, 4vw, 1.2rem);
      margin-bottom: 1rem;
      color: #2d3436;
    }

    .checkbox-group {
      margin: 0.8rem 0;
    }

    .checkbox-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin: 0.7rem 0;
      font-size: clamp(0.9rem, 3vw, 1rem);
      padding: 0.5rem;
      background: #f8f9fa;
      border-radius: 8px;
    }

    .checkbox-item input[type="checkbox"] {
      width: 20px;
      height: 20px;
      cursor: pointer;
      flex-shrink: 0;
      accent-color: #00b894;
    }

    .money-breakdown {
      background: linear-gradient(135deg, #1a7a3a 0%, #0d4d25 100%);
      color: white;
      padding: 0.8rem;
      border-radius: 10px;
      margin: 0.8rem 0;
      font-size: 0.85rem;
    }

    .money-breakdown div {
      display: flex;
      justify-content: space-between;
      margin: 0.3rem 0;
    }

    .money-breakdown .total {
      font-size: 1.2rem;
      font-weight: 800;
      color: #ffd700;
      border-top: 2px solid #ffd700;
      padding-top: 0.3rem;
      margin-top: 0.3rem;
    }

    .reward-message {
      text-align: center;
      margin-top: 0.8rem;
      padding: 0.8rem;
      background: linear-gradient(135deg, #ffeaa7 0%, #fdcb6e 100%);
      border-radius: 10px;
      font-weight: 700;
      font-size: clamp(0.9rem, 3vw, 1.1rem);
      color: #1a7a3a;
    }

    .streak-counter {
      text-align: center;
      margin: 0.8rem 0;
      padding: 0.8rem;
      font-size: clamp(0.9rem, 3.5vw, 1.1rem);
      font-weight: 700;
      background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
      border-radius: 10px;
      color: #1a1a1a;
    }

    .toast {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background: #2d3436;
      color: white;
      padding: 1rem;
      border-radius: 10px;
      display: none;
      z-index: 2000;
      animation: slideIn 0.3s ease;
      font-weight: 600;
      box-shadow: 0 10px 20px rgba(0,0,0,0.3);
      max-width: 300px;
    }

    @keyframes slideIn {
      from { 
        transform: translateX(100%);
        opacity: 0;
      }
      to { 
        transform: translateX(0);
        opacity: 1;
      }
    }

    @media (max-width: 360px) {
      body { 
        padding: 0.2rem; 
      }
      .app-container { 
        border-radius: 0.8rem; 
      }
      .calendar-grid { 
        gap: 2px; 
      }
      .day-cell { 
        min-height: 35px;
        border-radius: 6px;
      }
      .btn {
        padding: 0.3rem 0.5rem;
        font-size: 0.7rem;
      }
      .money-banner {
        padding: 0.6rem;
      }
    }
  </style>
</head>
<body>
  <div class="app-container">
    <div class="header">
      <h1>📅 Homework Money Tracker</h1>
      <p>💰 Earn Rands for good homework habits!</p>
    </div>

    <!-- Money Counter Banner -->
    <div class="money-banner">
      <div class="money-item">
        <div class="money-label">😊 Good Moods</div>
        <div class="money-value">R<span id="moodMoney">0.00</span></div>
        <div style="font-size: 0.7rem; color: #90EE90;">R2 each</div>
      </div>
      <div class="money-item">
        <div class="money-label">📚 Classwork</div>
        <div class="money-value">R<span id="classworkMoney">0.00</span></div>
        <div style="font-size: 0.7rem; color: #90EE90;">R2 each</div>
      </div>
      <div class="money-item">
        <div class="money-label">🎯 Bonuses</div>
        <div class="money-value">R<span id="bonusMoney">0.00</span></div>
        <div style="font-size: 0.7rem; color: #90EE90;">R1 per perfect day</div>
      </div>
      <div class="money-item">
        <div class="money-label">🏆 TOTAL EARNED</div>
        <div class="money-total">R<span id="totalMoney">0.00</span></div>
      </div>
    </div>

    <div class="sync-bar">
      <div class="sync-status">
        <div class="sync-dot" id="syncDot"></div>
        <span id="syncText">Ready to sync</span>
      </div>
      <div class="share-buttons">
        <button class="btn btn-gold" onclick="shareLink()">📤 Share</button>
        <button class="btn btn-primary" onclick="copyLink()">📋 Copy Link</button>
        <button class="btn btn-secondary" onclick="exportData()">💾 Backup</button>
        <button class="btn" onclick="importData()">📥 Restore</button>
      </div>
    </div>

    <div class="content">
      <div class="month-navigation">
        <button class="btn" onclick="changeMonth(-1)">◀ Prev</button>
        <div class="month-title" id="monthTitle">May 2026</div>
        <button class="btn" onclick="changeMonth(1)">Next ▶</button>
      </div>

      <div class="value-legend">
        💰 <strong>R2</strong> for each goal · <strong>R1 bonus</strong> when both achieved = <strong>R5</strong> perfect day!
      </div>

      <div class="calendar-grid" id="calendarGrid"></div>

      <div class="legend">
        <div class="legend-item">
          <div class="legend-color" style="background: linear-gradient(135deg, #a8e6cf, #88d8b0);"></div>
          <span>🌟 R5 Day</span>
        </div>
        <div class="legend-item">
          <div class="legend-color" style="background: linear-gradient(135deg, #ffd93d, #f4c531);"></div>
          <span>⚠️ R2 Day</span>
        </div>
        <div class="legend-item">
          <div class="legend-color" style="background: white; border: 2px solid #dfe6e9;"></div>
          <span>⬜ R0 Day</span>
        </div>
      </div>

      <div class="streak-counter" id="streakCounter">
        🔥 Current Streak: <span id="streakDays">0</span> perfect days!
      </div>
    </div>
  </div>

  <!-- Day Edit Modal -->
  <div class="modal" id="dayModal">
    <div class="modal-content">
      <h2 id="modalDate">Date</h2>
      <div class="checkbox-group">
        <div class="checkbox-item">
          <input type="checkbox" id="noBadMoods">
          <label for="noBadMoods">😊 No bad moods during homework <strong>(R2)</strong></label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="allClasswork">
          <label for="allClasswork">📚 Completed all classwork at school <strong>(R2)</strong></label>
        </div>
      </div>
      <div class="money-breakdown" id="moneyBreakdown">
        <div><span>Mood reward:</span> <span id="moodAmount">R0.00</span></div>
        <div><span>Classwork reward:</span> <span id="classworkAmount">R0.00</span></div>
        <div><span>Perfect day bonus:</span> <span id="bonusAmount">R0.00</span></div>
        <div class="total"><span>Today's total:</span> <span id="dayTotal">R0.00</span></div>
      </div>
      <div class="reward-message" id="dailyReward" style="display:none;">
        🎉 PERFECT DAY! You earned R5! 🎉
      </div>
      <div style="display: flex; gap: 0.8rem; margin-top: 1.2rem;">
        <button class="btn btn-gold" onclick="saveDay()" style="flex: 1;">💰 Save & Earn</button>
        <button class="btn" onclick="closeModal()" style="flex: 1; background: #b2bec3; color: white;">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div class="toast" id="toast"></div>

  <!-- Hidden file input for import -->
  <input type="file" id="importFile" accept=".json" style="display: none;" onchange="handleFileImport(event)">

  <script>
    // ==================== APP STATE ====================
    const STORAGE_KEY = 'homework_money_calendar';
    let calendarData = {};
    let currentDate = new Date();
    let selectedDay = null;

    // Money values
    const MOOD_VALUE = 2;      // R2 for no bad moods
    const CLASSWORK_VALUE = 2; // R2 for completed classwork
    const BONUS_VALUE = 1;     // R1 bonus when both achieved
    const PERFECT_DAY_TOTAL = MOOD_VALUE + CLASSWORK_VALUE + BONUS_VALUE; // R5

    // ==================== SYNC SYSTEM ====================
    let syncChannel = null;

    try {
      syncChannel = new BroadcastChannel('homework_money_channel');
      syncChannel.onmessage = (event) => {
        if (event.data && event.data.type === 'UPDATE') {
          loadData();
          renderCalendar();
          updateMoneyCounters();
          updateStreak();
          showToast('🔄 Updated by other parent');
        }
      };
    } catch (e) {
      console.log('BroadcastChannel not supported, using storage events');
    }

    window.addEventListener('storage', (e) => {
      if (e.key === STORAGE_KEY) {
        loadData();
        renderCalendar();
        updateMoneyCounters();
        updateStreak();
        showToast('🔄 Synced from other window');
      }
    });

    // ==================== DATA MANAGEMENT ====================
    function loadData() {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        try {
          calendarData = JSON.parse(saved);
        } catch (e) {
          calendarData = {};
        }
      } else {
        calendarData = {};
      }
    }

    function saveData() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(calendarData));
      
      if (syncChannel) {
        syncChannel.postMessage({ type: 'UPDATE', timestamp: Date.now() });
      }
      
      updateSyncStatus('saved');
    }

    function getDateKey(date) {
      return `${date.getFullYear()}-${(date.getMonth() + 1).toString().padStart(2, '0')}-${date.getDate().toString().padStart(2, '0')}`;
    }

    // ==================== MONEY CALCULATIONS ====================
    function calculateDayValue(dayData) {
      if (!dayData) return 0;
      
      let total = 0;
      if (dayData.noBadMoods) total += MOOD_VALUE;
      if (dayData.allClasswork) total += CLASSWORK_VALUE;
      if (dayData.noBadMoods && dayData.allClasswork) total += BONUS_VALUE;
      
      return total;
    }

    function calculateTotalMoney() {
      let moodCount = 0;
      let classworkCount = 0;
      let bonusCount = 0;
      
      Object.values(calendarData).forEach(dayData => {
        if (dayData.noBadMoods) moodCount++;
        if (dayData.allClasswork) classworkCount++;
        if (dayData.noBadMoods && dayData.allClasswork) bonusCount++;
      });
      
      return {
        moodMoney: moodCount * MOOD_VALUE,
        classworkMoney: classworkCount * CLASSWORK_VALUE,
        bonusMoney: bonusCount * BONUS_VALUE,
        totalMoney: (moodCount * MOOD_VALUE) + (classworkCount * CLASSWORK_VALUE) + (bonusCount * BONUS_VALUE),
        moodCount,
        classworkCount,
        bonusCount
      };
    }

    function updateMoneyCounters() {
      const money = calculateTotalMoney();
      
      document.getElementById('moodMoney').textContent = money.moodMoney.toFixed(2);
      document.getElementById('classworkMoney').textContent = money.classworkMoney.toFixed(2);
      document.getElementById('bonusMoney').textContent = money.bonusMoney.toFixed(2);
      document.getElementById('totalMoney').textContent = money.totalMoney.toFixed(2);
    }

    function updateModalMoney() {
      const noBadMoods = document.getElementById('noBadMoods').checked;
      const allClasswork = document.getElementById('allClasswork').checked;
      
      let moodAmount = noBadMoods ? MOOD_VALUE : 0;
      let classworkAmount = allClasswork ? CLASSWORK_VALUE : 0;
      let bonusAmount = (noBadMoods && allClasswork) ? BONUS_VALUE : 0;
      let total = moodAmount + classworkAmount + bonusAmount;
      
      document.getElementById('moodAmount').textContent = `R${moodAmount.toFixed(2)}`;
      document.getElementById('classworkAmount').textContent = `R${classworkAmount.toFixed(2)}`;
      document.getElementById('bonusAmount').textContent = `R${bonusAmount.toFixed(2)}`;
      document.getElementById('dayTotal').textContent = `R${total.toFixed(2)}`;
      
      const rewardDiv = document.getElementById('dailyReward');
      if (noBadMoods && allClasswork) {
        rewardDiv.style.display = 'block';
      } else {
        rewardDiv.style.display = 'none';
      }
    }

    // ==================== SHARING FUNCTIONS ====================
    function shareLink() {
      const url = window.location.href;
      
      if (navigator.share) {
        navigator.share({
          title: 'Homework Money Tracker',
          text: '💰 Track homework rewards and earn Rands! Both parents can update.',
          url: url,
        }).catch(() => {
          copyLink();
        });
      } else {
        copyLink();
        showToast('📋 Link copied! Share with other parent.');
      }
    }

    function copyLink() {
      const url = window.location
